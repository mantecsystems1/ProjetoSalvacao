# Copie para `.env` na raiz do projeto: `copy .env.example .env` (Windows) ou `cp .env.example .env`

# --- Compose (desenvolvimento) ---
POSTGRES_USER=biblia
POSTGRES_PASSWORD=biblia_dev
POSTGRES_DB=biblia_online

API_PORT=8080
WEB_PORT=3000

# URL que o *browser* usa para chamar a API (JSON). Em Docker local com portas publicadas:
PUBLIC_API_URL=http://localhost:8080
PUBLIC_SITE_URL=http://localhost:3000

# JWT (mínimo 32 caracteres)
JWT_ISSUER=biblia-online
JWT_AUDIENCE=biblia-online-clients
JWT_SIGNING_KEY=troque_esta_chaveJWT_para_um_segredo_longo_aleatorio_min_32
JWT_ACCESS_TOKEN_MINUTES=10080

# Meilisearch
MEILI_MASTER_KEY=dev_master_key_change_me
MEILI_INDEX=verses
MEILI_SYNC_ON_STARTUP=true

# Reindex manual via API (opcional): POST /api/v1/admin/search/reindex com header X-Admin-Key
ADMIN_REINDEX_KEY=

# --- Docker Swarm / produção (stack) ---
# DOMAIN=www.seudominio.com.br
# ACME_EMAIL=voce@dominio.com
# API_IMAGE=registry.example.com/biblia-online-api:1.0.0
# WEB_IMAGE=registry.example.com/biblia-online-web:1.0.0
